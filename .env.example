# Database Configuration
# Get a free PostgreSQL database from https://neon.tech
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# JWT Authentication Secrets
# Generate secure random strings using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_generate_64_byte_random_string
PLAIN_TEXT_SECRET=your_plain_text_secret_here_generate_64_byte_random_string

# Redis Configuration
# For local development with Docker: docker run -d -p 6379:6379 --name excali-redis redis:alpine
# Or get a free Redis instance from https://redis.io/try-free

# Option 1: Local Redis (default settings)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_DB=0

# Option 2: Cloud Redis (uncomment and use this instead of the above)
# REDIS_DB_URL=redis://username:password@host:port
