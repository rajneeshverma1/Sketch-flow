{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL", 
    "JWT_SECRET", 
    "PLAIN_TEXT_SECRET",
    "REDIS_DB_URL", 
    "REDIS_HOST",
    "REDIS_PORT",
    "REDIS_USERNAME",
    "REDIS_PASSWORD", 
    "REDIS_DB"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL", "JWT_SECRET", "PLAIN_TEXT_SECRET","REDIS_DB_URL", "REDIS_HOST","REDIS_PORT","REDIS_USERNAME","REDIS_PASSWORD", "REDIS_DB"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL", "JWT_SECRET", "PLAIN_TEXT_SECRET","REDIS_DB_URL", "REDIS_HOST","REDIS_PORT","REDIS_USERNAME","REDIS_PASSWORD", "REDIS_DB"]
    }
  }
}
